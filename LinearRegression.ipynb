   "source": [
    "from sklearn.linear_model import LinearRegression\n",
    "import numpy as np\n",
    "\n",
    "x = [1, 2, 3, 4, 5]\n",
    "y = [7, 14, 15, 18, 19]\n",
    "\n",
    "x = np.array(x).reshape(-1, 1)\n",
    "model = LinearRegression()\n",
    "model.fit(x,y)\n",
    "\n",
    "prediction = model.predict([[10]])\n",
    "print(\"Prediction:\", prediction)"
   ]
